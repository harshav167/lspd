{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.local/bin/lspd-session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "LSPD_SOCKET_PATH=\"$HOME\"/.factory/run/droid-lsp/lspd.sock \"$HOME\"/.local/bin/lsp-read-hook",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.local/bin/lspd stop --config \"$HOME\"/.local/bin/droid-lsp-config.yaml",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
